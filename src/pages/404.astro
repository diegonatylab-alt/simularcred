---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada | SimularCred"
  description="La página que buscas no existe o ha sido movida."
  canonical="https://simularcred.com/404"
>
  <main class="max-w-2xl mx-auto px-4 py-20 text-center">
    <p class="text-6xl font-extrabold text-primary-700 dark:text-primary-400 mb-4">404</p>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">Página no encontrada</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8">
      La simulación que buscas no existe o ha sido actualizada. Probá con nuestro simulador principal.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold bg-primary-700 text-white hover:bg-primary-800 transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" /></svg>
      Ir al simulador
    </a>
  </main>
</BaseLayout>
