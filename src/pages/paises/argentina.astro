---
import LandingLayout from '../../layouts/LandingLayout.astro';
import SimulatorApp from '../../components/SimulatorApp';
import FAQ from '../../components/FAQ.astro';
import { generateCombos } from '../../lib/landing-combos';

const arsCombos = generateCombos().filter((c) => c.currency === 'ARS').slice(0, 8);

const faqs = [
  {
    question: '¿Por qué las tasas en Argentina son tan altas?',
    answer: 'Argentina tiene históricamente alta inflación, lo que lleva a tasas nominales elevadas. La tasa política monetaria del BCRA influye directamente en las tasas de crédito.',
  },
  {
    question: '¿Cómo funciona un crédito UVA en Argentina?',
    answer: 'Los créditos UVA (Unidad de Valor Adquisitivo) se ajustan por inflación. La cuota inicial es baja pero se actualiza periódicamente según el índice de precios.',
  },
];
---

<LandingLayout
  title="Simulador de Crédito Argentina (ARS) | SimularCred"
  description="Calcula préstamos en pesos argentinos (ARS). Tabla de amortización para créditos en Argentina con tasas nominales anuales."
  canonical="https://simularcred.com/paises/argentina"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Países' },
    { label: 'Argentina' },
  ]}
>
  <h1 class="text-3xl font-extrabold text-primary-900 dark:text-primary-100 mb-2">🇦🇷 Simulador de Crédito en Argentina</h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">Calcula préstamos en pesos argentinos (ARS). Nota: las tasas nominales son elevadas por la inflación.</p>

  <div class="bg-sky-50 dark:bg-sky-900/20 border border-sky-200 dark:border-sky-800 rounded-xl p-4 mb-8 text-sm text-sky-800 dark:text-sky-300">
    <strong>Tasas de referencia Argentina 2024:</strong> Personal 60–100% TNA • Hipotecario UVA 4–8% + inflación
  </div>

  <SimulatorApp client:idle defaultAmount={5000000} defaultRate={60} defaultYears={3} currency="ARS" maxAmount={200000000} />

  <section class="mt-10 mb-8">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Simulaciones Populares en Argentina</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {arsCombos.map((c) => (
        <a href={`/simulador/${c.slug}`} class="bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-lg p-3 text-sm hover:border-primary-400 transition-colors">
          <span class="font-semibold text-primary-800 dark:text-primary-400">{c.title}</span>
        </a>
      ))}
    </div>
  </section>

  <FAQ items={faqs} />
</LandingLayout>
