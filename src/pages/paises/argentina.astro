---
import LandingLayout from '../../layouts/LandingLayout.astro';
import SimulatorApp from '../../components/SimulatorApp';
import SalaryCalculator from '../../components/SalaryCalculator';
import FAQ from '../../components/FAQ.astro';
import { generateCombos } from '../../lib/landing-combos';

const arsCombos = generateCombos().filter((c) => c.currency === 'ARS').slice(0, 8);

const faqs = [
  {
    question: '¿Por qué las tasas en Argentina son tan altas?',
    answer: 'Argentina tiene históricamente alta inflación, lo que lleva a tasas nominales elevadas. La tasa política monetaria del BCRA influye directamente en las tasas de crédito.',
  },
  {
    question: '¿Cómo funciona un crédito UVA en Argentina?',
    answer: 'Los créditos UVA (Unidad de Valor Adquisitivo) se ajustan por inflación. La cuota inicial es baja pero se actualiza periódicamente según el índice de precios.',
  },
];
---

<LandingLayout
  title="Simulador de Crédito Argentina (ARS) | SimularCred"
  description="Calcula préstamos en pesos argentinos (ARS). Tabla de amortización para créditos en Argentina con tasas nominales anuales."
  canonical="https://simularcred.com/paises/argentina"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Países' },
    { label: 'Argentina' },
  ]}
>
  <h1 class="text-3xl font-extrabold text-primary-900 dark:text-primary-100 mb-2"><img src="https://flagcdn.com/28x21/ar.png" alt="Bandera de Argentina" width="28" height="21" class="inline-block align-baseline mr-2" loading="eager" /> Simulador de Crédito en Argentina</h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">Calcula préstamos en pesos argentinos (ARS). Nota: las tasas nominales son elevadas por la inflación.</p>

  <div class="bg-sky-50 dark:bg-sky-900/20 border border-sky-200 dark:border-sky-800 rounded-xl p-4 mb-8 text-sm text-sky-800 dark:text-sky-300">
    <strong>Tasas de referencia Argentina 2024:</strong> Personal 60–100% TNA • Hipotecario UVA 4–8% + inflación
  </div>

  <SimulatorApp client:idle defaultAmount={5000000} defaultRate={60} defaultYears={3} currency="ARS" maxAmount={200000000} />

  <div class="mt-10 mb-10">
    <SalaryCalculator client:idle currency="ARS" />
  </div>

  <!-- Educational Content -->
  <section class="mt-10 mb-10 prose prose-primary dark:prose-invert max-w-none">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Créditos en Argentina: guía actualizada</h2>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      El mercado crediticio argentino tiene particularidades únicas debido a la <strong>alta inflación</strong> y la regulación del <strong>Banco Central de la República Argentina (BCRA)</strong>. Las tasas nominales son significativamente más altas que en otros países de la región, pero deben analizarse en contexto con la inflación.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Tipos de crédito en Argentina</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 not-prose mb-6">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Hipotecario UVA</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Ajustable por inflación (UVA). Tasas del 4% al 8% + UVA. Plazos de hasta 30 años. Requiere ingresos demostrables.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Personal</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">TNA del 60% al 100%+. Plazos de 12 a 60 meses. Tasa fija o variable según la entidad.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Prendario (Auto)</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">El vehículo queda en prenda. Tasas desde 40% TNA. Plazos de 12 a 60 meses. Financiación hasta el 70% del valor.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Préstamo ANSES</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Para jubilados y beneficiarios de asignaciones. Tasas subsidiadas. Descuento automático del haber mensual.</p>
      </div>
    </div>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">¿Qué es la TNA, TEA y CFT?</h3>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      En Argentina hay tres indicadores clave: la <strong>Tasa Nominal Anual (TNA)</strong> es la tasa base sin capitalización. La <strong>Tasa Efectiva Anual (TEA)</strong> incluye la capitalización de intereses. El <strong>Costo Financiero Total (CFT)</strong> es el indicador más completo, ya que incluye tasa, seguros, gastos administrativos y todos los costos asociados. Siempre compará usando el CFT.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Consideraciones especiales en Argentina</h3>
    <ul class="text-gray-700 dark:text-gray-300 space-y-2 mb-4">
      <li><strong>Inflación:</strong> en un contexto inflacionario, la tasa real (tasa nominal menos inflación) puede ser negativa, lo que hace que el crédito sea conveniente en términos reales.</li>
      <li><strong>Créditos UVA:</strong> las cuotas se ajustan por inflación, por lo que pueden crecer significativamente. Evalúa si tus ingresos acompañan esa variación.</li>
      <li><strong>Regulación BCRA:</strong> el Banco Central establece topes de tasas y condiciones mínimas. Verificá que tu entidad esté regulada.</li>
      <li><strong>Veraz:</strong> tu historial en el sistema Veraz/NOSIS influye directamente en la aprobación y la tasa ofrecida.</li>
    </ul>
  </section>

  <section class="mt-10 mb-8">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Simulaciones Populares en Argentina</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {arsCombos.map((c) => (
        <a href={`/simulador/${c.slug}`} class="bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-lg p-3 text-sm hover:border-primary-400 transition-colors">
          <span class="font-semibold text-primary-800 dark:text-primary-400">{c.title}</span>
        </a>
      ))}
    </div>
  </section>

  <FAQ items={faqs} />
</LandingLayout>
