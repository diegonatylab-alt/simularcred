---
import LandingLayout from '../../layouts/LandingLayout.astro';
import SimulatorApp from '../../components/SimulatorApp';
import FAQ from '../../components/FAQ.astro';
import { generateCombos } from '../../lib/landing-combos';

const clpCombos = generateCombos().filter((c) => c.currency === 'CLP').slice(0, 8);

const faqs = [
  {
    question: '¿Qué es la Tasa Máxima Convencional en Chile?',
    answer: 'La CMF fija la Tasa Máxima Convencional (TMC) mensualmente. Los créditos no pueden superar esta tasa, que suele ser alrededor del 50% por sobre el promedio del mercado.',
  },
  {
    question: '¿Cómo funciona la CAE en Chile?',
    answer: 'La Carga Anual Equivalente (CAE) incluye tasa, comisiones y seguros. Es el indicador oficial para comparar créditos en Chile bajo la Ley 20.555.',
  },
];
---

<LandingLayout
  title="Simulador de Crédito Chile (CLP) | SimularCred"
  description="Calcula préstamos en pesos chilenos (CLP). Tabla de amortización y cuotas para créditos en Chile."
  canonical="https://simuladorcredito.lat/paises/chile"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Países' },
    { label: 'Chile' },
  ]}
>
  <h1 class="text-3xl font-extrabold text-primary-900 dark:text-primary-100 mb-2">🇨🇱 Simulador de Crédito en Chile</h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">Calcula préstamos en pesos chilenos (CLP) con las tasas del mercado chileno.</p>

  <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-4 mb-8 text-sm text-red-800 dark:text-red-300">
    <strong>Tasas de referencia Chile 2024:</strong> Hipotecario 4–7% • Consumo 12–24% • Automotriz 8–14%
  </div>

  <SimulatorApp client:idle defaultAmount={10000000} defaultRate={8} defaultYears={5} currency="CLP" />

  <section class="mt-10 mb-8">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Simulaciones Populares en Chile</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {clpCombos.map((c) => (
        <a href={`/simulador/${c.slug}`} class="bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-lg p-3 text-sm hover:border-primary-400 transition-colors">
          <span class="font-semibold text-primary-800 dark:text-primary-400">{c.title}</span>
        </a>
      ))}
    </div>
  </section>

  <FAQ items={faqs} />
</LandingLayout>
