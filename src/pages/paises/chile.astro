---
import LandingLayout from '../../layouts/LandingLayout.astro';
import SimulatorApp from '../../components/SimulatorApp';
import SalaryCalculator from '../../components/SalaryCalculator';
import FAQ from '../../components/FAQ.astro';
import { generateCombos } from '../../lib/landing-combos';

const clpCombos = generateCombos().filter((c) => c.currency === 'CLP').slice(0, 8);

const faqs = [
  {
    question: '¿Qué es la Tasa Máxima Convencional en Chile?',
    answer: 'La CMF fija la Tasa Máxima Convencional (TMC) mensualmente. Los créditos no pueden superar esta tasa, que suele ser alrededor del 50% por sobre el promedio del mercado.',
  },
  {
    question: '¿Cómo funciona la CAE en Chile?',
    answer: 'La Carga Anual Equivalente (CAE) incluye tasa, comisiones y seguros. Es el indicador oficial para comparar créditos en Chile bajo la Ley 20.555.',
  },
];
---

<LandingLayout
  title="Simulador de Crédito Chile (CLP) | SimularCred"
  description="Calcula préstamos en pesos chilenos (CLP). Tabla de amortización y cuotas para créditos en Chile."
  canonical="https://simularcred.com/paises/chile"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Países' },
    { label: 'Chile' },
  ]}
>
  <h1 class="text-3xl font-extrabold text-primary-900 dark:text-primary-100 mb-2"><img src="https://flagcdn.com/28x21/cl.png" alt="Bandera de Chile" width="28" height="21" class="inline-block align-baseline mr-2" loading="eager" /> Simulador de Crédito en Chile</h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">Calcula préstamos en pesos chilenos (CLP) con las tasas del mercado chileno.</p>

  <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-4 mb-8 text-sm text-red-800 dark:text-red-300">
    <strong>Tasas de referencia Chile 2024:</strong> Hipotecario 4–7% • Consumo 12–24% • Automotriz 8–14%
  </div>

  <SimulatorApp client:idle defaultAmount={10000000} defaultRate={8} defaultYears={5} currency="CLP" />

  <div class="mt-10 mb-10">
    <SalaryCalculator client:idle currency="CLP" />
  </div>

  <!-- Educational Content -->
  <section class="mt-10 mb-10 prose prose-primary dark:prose-invert max-w-none">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Créditos en Chile: guía completa</h2>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      Chile cuenta con un sistema financiero robusto regulado por la <strong>Comisión para el Mercado Financiero (CMF)</strong>. Las tasas de interés en Chile son de las más bajas de América Latina, especialmente para créditos hipotecarios, gracias a la estabilidad macroeconómica del país.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Tipos de crédito en Chile</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 not-prose mb-6">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Hipotecario</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">En UF o pesos. Tasas del 4% al 7% anual. Plazos de hasta 30 años. Financiamiento hasta el 80% del valor de la propiedad.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito de Consumo</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Tasas del 12% al 24% anual. Plazos de 6 a 60 meses. Requiere antigüedad laboral mínima y renta comprobable.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Automotriz</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Tasas del 8% al 14%. Plazos de 24 a 60 meses. El vehículo queda en prenda. Pie mínimo del 10-20%.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito con Aval del Estado (CAE)</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Para estudios superiores. Tasa del 2% anual. El Estado garantiza el crédito. Pago comienza después de egresar.</p>
      </div>
    </div>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">¿Qué es la UF y cómo afecta tu crédito?</h3>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      La <strong>Unidad de Fomento (UF)</strong> es una unidad de cuenta indexada a la inflación que se actualiza diariamente. Los créditos hipotecarios en Chile se pactan mayoritariamente en UF, lo que significa que tu deuda mantiene su valor real. La ventaja es que las tasas en UF son más bajas; la desventaja es que el monto en pesos puede crecer si hay inflación alta.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Recomendaciones para créditos en Chile</h3>
    <ul class="text-gray-700 dark:text-gray-300 space-y-2 mb-4">
      <li><strong>Compara la Carga Anual Equivalente (CAE):</strong> es el indicador que incluye todos los costos y permite comparar entre instituciones.</li>
      <li><strong>Verifica la Tasa Máxima Convencional (TMC):</strong> ningún crédito puede superar esta tasa regulada por la CMF.</li>
      <li><strong>Usa la portabilidad financiera:</strong> puedes trasladar tu crédito a otro banco con mejores condiciones sin costo.</li>
      <li><strong>Cotiza en cooperativas y cajas de compensación:</strong> suelen ofrecer tasas competitivas con menos requisitos.</li>
    </ul>
  </section>

  <section class="mt-10 mb-8">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Simulaciones Populares en Chile</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {clpCombos.map((c) => (
        <a href={`/simulador/${c.slug}`} class="bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-lg p-3 text-sm hover:border-primary-400 transition-colors">
          <span class="font-semibold text-primary-800 dark:text-primary-400">{c.title}</span>
        </a>
      ))}
    </div>
  </section>

  <FAQ items={faqs} />
</LandingLayout>
