---
import LandingLayout from '../../layouts/LandingLayout.astro';
import SimulatorApp from '../../components/SimulatorApp';
import SalaryCalculator from '../../components/SalaryCalculator';
import FAQ from '../../components/FAQ.astro';
import { generateCombos } from '../../lib/landing-combos';

const copCombos = generateCombos().filter((c) => c.currency === 'COP').slice(0, 8);

const faqs = [
  {
    question: '¿Cuál es la tasa de usura en Colombia?',
    answer: 'La Superintendencia Financiera de Colombia fija la tasa de usura cada trimestre. En 2024 se ubica alrededor del 32–38% efectivo anual para créditos de consumo.',
  },
  {
    question: '¿Qué es la tasa EA en Colombia?',
    answer: 'La tasa EA (Efectiva Anual) es el estándar en Colombia para expresar tasas de interés, incluyendo la capitalización de intereses.',
  },
];
---

<LandingLayout
  title="Simulador de Crédito Colombia (COP) | SimularCred"
  description="Calcula préstamos en pesos colombianos (COP). Tabla de amortización y cuotas para créditos en Colombia."
  canonical="https://simularcred.com/paises/colombia"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Países' },
    { label: 'Colombia' },
  ]}
>
  <h1 class="text-3xl font-extrabold text-primary-900 dark:text-primary-100 mb-2"><img src="https://flagcdn.com/28x21/co.png" alt="Bandera de Colombia" width="28" height="21" class="inline-block align-baseline mr-2" loading="eager" /> Simulador de Crédito en Colombia</h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">Calcula préstamos en pesos colombianos (COP) con las tasas del mercado colombiano.</p>

  <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-xl p-4 mb-8 text-sm text-yellow-800 dark:text-yellow-300">
    <strong>Tasas de referencia Colombia 2024:</strong> Hipotecario (VIS) 10–14% • Personal 18–32% • Microcrédito 30–38%
  </div>

  <SimulatorApp client:idle defaultAmount={20000000} defaultRate={14} defaultYears={5} currency="COP" />

  <div class="mt-10 mb-10">
    <SalaryCalculator client:idle currency="COP" />
  </div>

  <!-- Educational Content -->
  <section class="mt-10 mb-10 prose prose-primary dark:prose-invert max-w-none">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Créditos en Colombia: todo lo que debes saber</h2>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      El sistema financiero colombiano está regulado por la <strong>Superintendencia Financiera de Colombia (SFC)</strong>. Bancos, cooperativas y fintechs ofrecen productos crediticios con tasas que no pueden superar la <strong>tasa de usura</strong> establecida trimestralmente por la SFC.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Tipos de crédito en Colombia</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 not-prose mb-6">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito de Vivienda (VIS/No VIS)</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Vivienda de Interés Social (VIS) con subsidios. Tasas del 10% al 14%. Plazos de hasta 20 años en pesos o UVR.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito de Consumo</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Libre inversión. Tasas del 18% al 32% anual. Plazos de 12 a 72 meses. Requiere historial en centrales de riesgo.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Microcrédito</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Para microempresarios. Montos menores. Tasas del 30% al 38%. Regulado con tasa de usura específica.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito de Libranza</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Descuento directo de nómina. Tasas preferenciales. Disponible para empleados con contrato laboral vigente.</p>
      </div>
    </div>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">¿Qué es la tasa de usura?</h3>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      La tasa de usura es el límite máximo de interés que las entidades financieras pueden cobrar en Colombia. Es fijada cada trimestre por la Superintendencia Financiera y equivale a 1.5 veces el interés bancario corriente. Ningún crédito legal puede superar esta tasa.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Consejos para créditos en Colombia</h3>
    <ul class="text-gray-700 dark:text-gray-300 space-y-2 mb-4">
      <li><strong>Consulta Datacrédito y TransUnion:</strong> tu score crediticio determina la tasa y aprobación. Puedes consultarlo gratis una vez al mes.</li>
      <li><strong>Compara la Tasa Efectiva Anual (TEA):</strong> es más representativa que la tasa nominal porque incluye la capitalización de intereses.</li>
      <li><strong>Créditos en UVR:</strong> para vivienda, la Unidad de Valor Real se ajusta por inflación. Conveniente cuando la inflación es baja.</li>
      <li><strong>Aprovecha subsidios:</strong> programas como Mi Casa Ya ofrecen subsidios a la tasa y al cuota inicial para vivienda VIS.</li>
    </ul>
  </section>

  <section class="mt-10 mb-8">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Simulaciones Populares en Colombia</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {copCombos.map((c) => (
        <a href={`/simulador/${c.slug}`} class="bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-lg p-3 text-sm hover:border-primary-400 transition-colors">
          <span class="font-semibold text-primary-800 dark:text-primary-400">{c.title}</span>
        </a>
      ))}
    </div>
  </section>

  <FAQ items={faqs} />
</LandingLayout>
