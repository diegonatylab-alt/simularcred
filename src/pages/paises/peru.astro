---
import LandingLayout from '../../layouts/LandingLayout.astro';
import SimulatorApp from '../../components/SimulatorApp';
import SalaryCalculator from '../../components/SalaryCalculator';
import FAQ from '../../components/FAQ.astro';
import { generateCombos } from '../../lib/landing-combos';

const penCombos = generateCombos().filter((c) => c.currency === 'PEN').slice(0, 8);

const faqs = [
  {
    question: '¿Qué es la TCEA en Perú?',
    answer: 'La Tasa de Costo Efectivo Anual (TCEA) incluye todos los costos del crédito: tasa nominal, comisiones, portes y seguros. Es el indicador regulado por la SBS.',
  },
  {
    question: '¿Cuáles son las tasas para créditos hipotecarios en Perú?',
    answer: 'En 2024, las tasas para créditos hipotecarios en soles (PEN) se ubican entre 8% y 14% anual, dependiendo del banco y el perfil del solicitante.',
  },
];
---

<LandingLayout
  title="Simulador de Crédito Perú (PEN) | SimularCred"
  description="Calcula préstamos en soles peruanos (PEN). Tabla de amortización y cuotas para créditos en Perú."
  canonical="https://simularcred.com/paises/peru"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Países' },
    { label: 'Perú' },
  ]}
>
  <h1 class="text-3xl font-extrabold text-primary-900 dark:text-primary-100 mb-2"><img src="https://flagcdn.com/28x21/pe.png" alt="Bandera de Perú" width="28" height="21" class="inline-block align-baseline mr-2" loading="eager" /> Simulador de Crédito en Perú</h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">Calcula préstamos en soles peruanos (PEN) con las tasas del mercado peruano.</p>

  <div class="bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800 rounded-xl p-4 mb-8 text-sm text-orange-800 dark:text-orange-300">
    <strong>Tasas de referencia Perú 2024:</strong> Hipotecario 8–14% • Personal 15–40% • Consumo 20–50%
  </div>

  <SimulatorApp client:idle defaultAmount={50000} defaultRate={12} defaultYears={5} currency="PEN" />

  <div class="mt-10 mb-10">
    <SalaryCalculator client:idle currency="PEN" />
  </div>

  <!-- Educational Content -->
  <section class="mt-10 mb-10 prose prose-primary dark:prose-invert max-w-none">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Créditos en Perú: lo que debes saber</h2>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      El sistema financiero peruano está regulado por la <strong>Superintendencia de Banca, Seguros y AFP (SBS)</strong>. Perú cuenta con bancos, cajas municipales, cajas rurales y financieras que ofrecen productos crediticios para todos los segmentos. Las tasas varían significativamente según el tipo de crédito y la entidad.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Tipos de crédito en Perú</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 not-prose mb-6">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Hipotecario</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Tasas del 8% al 14% anual en soles. Plazos de hasta 25 años. Financiamiento del 80-90% del valor del inmueble.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Personal</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Tasas del 15% al 40% anual. Plazos de 12 a 60 meses. Disponible en bancos, financieras y fintechs.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Vehicular</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Tasas del 10% al 20%. Plazos de 12 a 60 meses. Cuota inicial del 10-20%. El vehículo queda en garantía.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito MiVivienda</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Programa estatal con Bono del Buen Pagador. Tasas preferenciales. Para viviendas de S/ 65,200 a S/ 464,200.</p>
      </div>
    </div>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">¿Qué es la TCEA?</h3>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      La <strong>Tasa de Costo Efectivo Anual (TCEA)</strong> es el indicador más importante para comparar créditos en Perú. Incluye la tasa de interés, comisiones, portes, seguros y todos los gastos asociados. La SBS obliga a todas las entidades a informar la TCEA. Siempre usa este indicador para comparar, no la tasa nominal.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Consejos para créditos en Perú</h3>
    <ul class="text-gray-700 dark:text-gray-300 space-y-2 mb-4">
      <li><strong>Consulta el Reporte de Deudas SBS:</strong> puedes verificar gratis tu historial crediticio en la página de la SBS.</li>
      <li><strong>Compara en las cajas municipales:</strong> suelen ofrecer mejores tasas que los bancos para montos pequeños y medianos.</li>
      <li><strong>Programa MiVivienda:</strong> si buscas vivienda, investiga el Bono del Buen Pagador que subsidia parte del crédito.</li>
      <li><strong>Cuidado con las fintechs no reguladas:</strong> verifica que la entidad esté supervisada por la SBS antes de solicitar un préstamo.</li>
    </ul>
  </section>

  <section class="mt-10 mb-8">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Simulaciones Populares en Perú</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {penCombos.map((c) => (
        <a href={`/simulador/${c.slug}`} class="bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-lg p-3 text-sm hover:border-primary-400 transition-colors">
          <span class="font-semibold text-primary-800 dark:text-primary-400">{c.title}</span>
        </a>
      ))}
    </div>
  </section>

  <FAQ items={faqs} />
</LandingLayout>
