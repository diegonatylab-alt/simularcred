---
import LandingLayout from '../../layouts/LandingLayout.astro';
import SimulatorApp from '../../components/SimulatorApp';
import SalaryCalculator from '../../components/SalaryCalculator';
import FAQ from '../../components/FAQ.astro';
import { generateCombos } from '../../lib/landing-combos';

const mxnCombos = generateCombos().filter((c) => c.currency === 'MXN').slice(0, 8);

const faqs = [
  {
    question: '¿Cuál es la tasa de interés promedio para créditos personales en México?',
    answer: 'En 2024, las tasas para créditos personales en México oscilan entre 20% y 80% anual según el banco. Para créditos hipotecarios, entre 9% y 14% anual.',
  },
  {
    question: '¿Qué es el CAT en México?',
    answer: 'El Costo Anual Total (CAT) incluye tasa de interés, comisiones y todos los costos del crédito. Es el indicador regulado por Banxico para comparar productos financieros.',
  },
  {
    question: '¿Cuáles son los principales bancos que ofrecen créditos en México?',
    answer: 'BBVA, Banorte, Santander, HSBC, Scotiabank, Citibanamex y muchas instituciones de microfinanzas como Compartamos.',
  },
];
---

<LandingLayout
  title="Simulador de Crédito México (MXN) | SimularCred"
  description="Calcula préstamos en pesos mexicanos (MXN). Tasas vigentes, tabla de amortización francesa y alemana para créditos en México."
  canonical="https://simularcred.com/paises/mexico"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Países' },
    { label: 'México' },
  ]}
>
  <h1 class="text-3xl font-extrabold text-primary-900 dark:text-primary-100 mb-2"><img src="https://flagcdn.com/28x21/mx.png" alt="Bandera de México" width="28" height="21" class="inline-block align-baseline mr-2" loading="eager" /> Simulador de Crédito en México</h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">Calcula préstamos en pesos mexicanos (MXN) con las tasas referenciales del mercado.</p>

  <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-4 mb-8 text-sm text-amber-800 dark:text-amber-300">
    <strong>Tasas de referencia México 2024:</strong> Hipotecario 9–14% • Personal 20–80% • Nómina 15–35% • Auto 8–15%
  </div>

  <SimulatorApp client:idle defaultAmount={200000} defaultRate={12} defaultYears={10} currency="MXN" />

  <div class="mt-10 mb-10">
    <SalaryCalculator client:idle currency="MXN" />
  </div>

  <!-- Educational Content -->
  <section class="mt-10 mb-10 prose prose-primary dark:prose-invert max-w-none">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Créditos en México: lo que necesitas saber</h2>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      El sistema financiero mexicano ofrece una amplia variedad de productos crediticios regulados por la <strong>Comisión Nacional Bancaria y de Valores (CNBV)</strong> y el <strong>Banco de México (Banxico)</strong>. Antes de solicitar un crédito, es fundamental entender los indicadores clave y comparar opciones.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Tipos de crédito disponibles en México</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 not-prose mb-6">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Hipotecario</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Plazos de 10 a 20 años. Tasas desde 9% anual. Requiere enganche del 10-20% y buró de crédito favorable.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Personal</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Sin garantía, plazos de 1 a 5 años. Tasas del 20% al 80% anual según historial crediticio y monto.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito de Nómina</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Descuento directo de tu sueldo. Tasas del 15% al 35%. Requisito: recibir nómina en el banco emisor.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Crédito Automotriz</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Plazos de 2 a 6 años. Tasas del 8% al 15%. El vehículo queda como garantía hasta liquidar la deuda.</p>
      </div>
    </div>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">¿Qué es el CAT y por qué es importante?</h3>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      El <strong>Costo Anual Total (CAT)</strong> es un indicador regulado por Banxico que incluye la tasa de interés, comisiones, primas de seguros y todos los gastos asociados al crédito. Es la forma más confiable de comparar productos financieros, ya que la tasa de interés por sí sola no refleja el costo real. Siempre solicita el CAT antes de firmar un contrato de crédito.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Consejos para obtener mejores tasas en México</h3>
    <ul class="text-gray-700 dark:text-gray-300 space-y-2 mb-4">
      <li><strong>Mantén un buen historial en Buró de Crédito:</strong> un score alto te da acceso a tasas preferenciales.</li>
      <li><strong>Compara al menos 3 instituciones:</strong> bancos, Sofomes y fintechs ofrecen condiciones muy diferentes.</li>
      <li><strong>Negocia el CAT, no solo la tasa:</strong> las comisiones de apertura pueden representar un costo significativo.</li>
      <li><strong>Considera créditos de organismos públicos:</strong> INFONAVIT y FOVISSSTE ofrecen tasas subsidiadas para vivienda.</li>
    </ul>
  </section>

  <section class="mt-10 mb-8">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Simulaciones Populares en México</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {mxnCombos.map((c) => (
        <a href={`/simulador/${c.slug}`} class="bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-lg p-3 text-sm hover:border-primary-400 transition-colors">
          <span class="font-semibold text-primary-800 dark:text-primary-400">{c.title}</span>
        </a>
      ))}
    </div>
  </section>

  <FAQ items={faqs} />
</LandingLayout>
