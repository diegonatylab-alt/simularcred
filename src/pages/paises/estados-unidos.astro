---
import LandingLayout from '../../layouts/LandingLayout.astro';
import SimulatorApp from '../../components/SimulatorApp';
import SalaryCalculator from '../../components/SalaryCalculator';
import FAQ from '../../components/FAQ.astro';
import { generateCombos } from '../../lib/landing-combos';

const usdCombos = generateCombos().filter((c) => c.currency === 'USD').slice(0, 8);

const faqs = [
  {
    question: '¿Cuáles son las tasas de interés típicas en Estados Unidos?',
    answer: 'En 2024, las tasas hipotecarias rondan el 6–8% anual, los préstamos personales entre 8–15% y los préstamos para auto entre 5–10%, dependiendo del puntaje crediticio.',
  },
  {
    question: '¿Qué es el credit score y cómo afecta mi crédito?',
    answer: 'El credit score (puntaje de crédito) es un número entre 300 y 850 que refleja tu historial crediticio. A mayor puntaje, mejores tasas y condiciones de préstamo puedes obtener.',
  },
  {
    question: '¿Qué tipos de préstamos son comunes en Estados Unidos?',
    answer: 'Los más comunes son hipotecarios (mortgage), préstamos personales (personal loans), préstamos para auto (auto loans) y líneas de crédito (HELOC). Cada uno tiene tasas y plazos diferentes.',
  },
];
---

<LandingLayout
  title="Simulador de Crédito Estados Unidos (USD) | SimularCred"
  description="Calcula préstamos en dólares estadounidenses (USD). Tabla de amortización francesa y alemana para créditos en Estados Unidos."
  canonical="https://simularcred.com/paises/estados-unidos"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Países' },
    { label: 'Estados Unidos' },
  ]}
>
  <h1 class="text-3xl font-extrabold text-primary-900 dark:text-primary-100 mb-2"><img src="https://flagcdn.com/28x21/us.png" alt="Bandera de Estados Unidos" width="28" height="21" class="inline-block align-baseline mr-2" loading="eager" /> Simulador de Crédito en Estados Unidos</h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">Calcula préstamos en dólares estadounidenses (USD) con las tasas referenciales del mercado.</p>

  <div class="bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-800 rounded-xl p-4 mb-8 text-sm text-indigo-800 dark:text-indigo-300">
    <strong>Tasas de referencia EE.UU. 2024:</strong> Hipotecario 6–8% • Personal 8–15% • Auto 5–10% • Estudiantil 5–8%
  </div>

  <SimulatorApp client:idle defaultAmount={50000} defaultRate={8} defaultYears={5} currency="USD" />

  <div class="mt-10 mb-10">
    <SalaryCalculator client:idle currency="USD" />
  </div>

  <!-- Educational Content -->
  <section class="mt-10 mb-10 prose prose-primary dark:prose-invert max-w-none">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Créditos en Estados Unidos: guía para hispanohablantes</h2>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      El sistema crediticio de Estados Unidos es uno de los más desarrollados del mundo. Está regulado por múltiples agencias federales incluyendo la <strong>Federal Reserve</strong>, la <strong>FDIC</strong> y el <strong>Consumer Financial Protection Bureau (CFPB)</strong>. Tu <strong>credit score</strong> es el factor determinante para obtener las mejores tasas.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Tipos de préstamos en Estados Unidos</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 not-prose mb-6">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Mortgage (Hipotecario)</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Fixed-rate o ARM. Tasas del 6% al 8%. Plazos de 15 o 30 años. Down payment del 3-20%. Requiere credit score 620+.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Personal Loan</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Tasas del 8% al 15% para buen crédito. Plazos de 2 a 7 años. Disponible en bancos, credit unions y fintechs.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Auto Loan</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Tasas del 5% al 10% para autos nuevos. Plazos de 36 a 72 meses. Financiamiento en dealer o banco directo.</p>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-1 text-sm">Student Loan</h4>
        <p class="text-xs text-gray-600 dark:text-gray-400">Federal (5-8%) o privado. Federal ofrece income-driven repayment. Posibilidad de loan forgiveness en programas públicos.</p>
      </div>
    </div>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">¿Qué es el credit score y por qué es crucial?</h3>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      El <strong>credit score</strong> (puntaje FICO) va de 300 a 850 y determina si calificas para un préstamo y a qué tasa. Un score de 740+ te da acceso a las mejores tasas. Se basa en tu historial de pagos (35%), montos adeudados (30%), antigüedad crediticia (15%), tipos de crédito (10%) y consultas recientes (10%). Puedes consultarlo gratis en AnnualCreditReport.com.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-6 mb-3">Consejos para hispanohablantes en EE.UU.</h3>
    <ul class="text-gray-700 dark:text-gray-300 space-y-2 mb-4">
      <li><strong>Construye tu credit history:</strong> si eres recién llegado, una tarjeta asegurada (secured credit card) es el primer paso para construir historial.</li>
      <li><strong>Compara el APR:</strong> el Annual Percentage Rate incluye la tasa y costos del préstamo. Es el equivalente al CAT o TCEA de Latinoamérica.</li>
      <li><strong>Explora credit unions:</strong> las cooperativas de crédito suelen ofrecer mejores tasas y menos requisitos que los grandes bancos.</li>
      <li><strong>Programas FHA:</strong> la Federal Housing Administration respalda hipotecas con down payment desde 3.5% para compradores primerizos.</li>
    </ul>
  </section>

  <section class="mt-10 mb-8">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">Simulaciones Populares en Estados Unidos</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {usdCombos.map((c) => (
        <a href={`/simulador/${c.slug}`} class="bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-lg p-3 text-sm hover:border-primary-400 transition-colors">
          <span class="font-semibold text-primary-800 dark:text-primary-400">{c.title}</span>
        </a>
      ))}
    </div>
  </section>

  <FAQ items={faqs} />
</LandingLayout>
