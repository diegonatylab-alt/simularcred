---
import LandingLayout from '../layouts/LandingLayout.astro';
import SimulatorApp from '../components/SimulatorApp';
import SalaryCalculator from '../components/SalaryCalculator';
import AdUnit from '../components/AdUnit.astro';
import FAQ from '../components/FAQ.astro';
import { generateCombos } from '../lib/landing-combos';

const allCombos = generateCombos();
const currencies = ['MXN', 'COP', 'CLP', 'PEN', 'ARS', 'USD'];
const popularCombos = currencies.flatMap((cur) =>
  allCombos.filter((c) => c.currency === cur).slice(0, 2)
);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Simulador de Crédito LATAM',
  url: 'https://simularcred.com',
  description: 'Calculadora de préstamos y simulador de crédito para América Latina con amortización francesa y alemana.',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const faqs = [
  {
    question: '¿Qué es la amortización francesa?',
    answer: 'La amortización francesa es un sistema en el que la cuota mensual es fija durante toda la vida del préstamo. Al inicio se paga más interés y al final más capital.',
  },
  {
    question: '¿Qué es la amortización alemana?',
    answer: 'En la amortización alemana, el capital que se paga cada mes es fijo, pero la cuota total varía porque los intereses disminuyen conforme se reduce el saldo.',
  },
  {
    question: '¿Cuál sistema de amortización conviene más?',
    answer: 'Depende de tu situación. El sistema francés ofrece cuotas fijas predecibles. El sistema alemán paga menos intereses totales, pero las primeras cuotas son más altas.',
  },
  {
    question: '¿Para qué países sirve esta calculadora?',
    answer: 'SimularCred está diseñado para México (MXN), Colombia (COP), Chile (CLP), Perú (PEN), Argentina (ARS) y Estados Unidos (USD).',
  },
  {
    question: '¿Es gratuita la calculadora?',
    answer: 'Sí, la calculadora es completamente gratuita. Solo necesitas ingresar el monto, la tasa de interés y el plazo para obtener tu tabla de amortización al instante.',
  },
];
---

<LandingLayout
  title="Simulador de Crédito — Calculadora de Préstamos LATAM | SimularCred"
  description="Simula préstamos en México, Colombia, Chile, Perú y Argentina. Calcula cuotas, tabla de amortización francesa y alemana. Gratis y sin registro."
  canonical="https://simularcred.com/"
  schema={schema}
>
  <!-- Hero -->
  <section class="text-center py-12 md:py-16">
    <h1 class="text-3xl md:text-5xl font-extrabold text-primary-900 dark:text-primary-100 mb-4 leading-tight">
      Simulador de Crédito —<br class="hidden md:block" /> Calculadora de Préstamos LATAM
    </h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-8">
      Calcula tu cuota mensual, tabla de amortización y costo total del crédito en MXN, COP, CLP, PEN, ARS y USD. Sistemas francés y alemán.
    </p>
  </section>

  <!-- Simulator App Island (Calculator + Chart + Table with shared state) -->
  <section class="mb-10">
    <SimulatorApp client:idle defaultAmount={100000} defaultRate={12} defaultYears={5} currency="MXN" />
  </section>

  <!-- Salary Calculator -->
  <section class="mb-10">
    <SalaryCalculator client:idle />
  </section>

  <AdUnit slot="top-ad" format="horizontal" />

  <!-- Educational Content -->
  <section class="mb-10 prose prose-primary dark:prose-invert max-w-none">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-4">¿Cómo funciona un simulador de crédito?</h2>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      Un simulador de crédito es una herramienta financiera que te permite conocer de antemano cuánto pagarás mensualmente por un préstamo, cuánto destinarás a intereses y cuánto al capital. En SimularCred calculamos tu crédito con dos sistemas de amortización: el <strong>sistema francés</strong> (cuota fija) y el <strong>sistema alemán</strong> (capital fijo), para que puedas comparar y tomar la mejor decisión.
    </p>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      Solo necesitas ingresar tres datos: el <strong>monto del préstamo</strong>, la <strong>tasa de interés anual</strong> y el <strong>plazo en años</strong>. La calculadora genera automáticamente la tabla de amortización completa, un gráfico de evolución del saldo y un resumen comparativo entre ambos sistemas.
    </p>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-8 mb-3">¿Qué diferencia hay entre el sistema francés y el alemán?</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose mb-6">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-5">
        <h4 class="font-bold text-primary-800 dark:text-primary-400 mb-2">Sistema Francés</h4>
        <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
          <li>✓ Cuota mensual fija durante todo el plazo</li>
          <li>✓ Al inicio se paga más interés, al final más capital</li>
          <li>✓ Ideal si necesitas previsibilidad en tu presupuesto</li>
          <li>✗ Pagas más intereses totales que con el sistema alemán</li>
        </ul>
      </div>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-5">
        <h4 class="font-bold text-green-800 dark:text-green-400 mb-2">Sistema Alemán</h4>
        <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
          <li>✓ Amortización de capital constante cada mes</li>
          <li>✓ Las cuotas van disminuyendo con el tiempo</li>
          <li>✓ Menor costo total de intereses</li>
          <li>✗ La primera cuota es más alta que en el francés</li>
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-8 mb-3">5 consejos antes de solicitar un crédito</h3>
    <ol class="text-gray-700 dark:text-gray-300 space-y-3 mb-6 list-decimal list-inside">
      <li><strong>Compara varias opciones:</strong> no te quedes con la primera oferta. Usa esta calculadora para simular distintos escenarios de tasa y plazo.</li>
      <li><strong>Revisa tu capacidad de pago:</strong> los expertos recomiendan que la cuota del crédito no supere el 30% de tu sueldo neto mensual. Usa nuestra calculadora inversa para saber cuánto te pueden prestar.</li>
      <li><strong>Entiende la tasa efectiva:</strong> la tasa nominal no refleja el costo real. Pregunta por la TCEA (Perú), CAT (México) o Tasa Efectiva Anual según tu país.</li>
      <li><strong>Considera los costos adicionales:</strong> seguros, comisiones de apertura, gastos notariales y portes pueden aumentar significativamente el costo total.</li>
      <li><strong>Lee la letra pequeña:</strong> verifica penalizaciones por pago anticipado, condiciones de refinanciamiento y qué pasa si te atrasas en un pago.</li>
    </ol>

    <h3 class="text-xl font-bold text-primary-800 dark:text-primary-400 mt-8 mb-3">¿Qué es la tabla de amortización?</h3>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      La tabla de amortización es el desglose mes a mes de tu crédito. Muestra cuánto pagas de cuota, qué parte va a intereses, qué parte va a reducir tu deuda (capital) y cuánto te queda por pagar. Es la herramienta más transparente para entender el verdadero costo de un préstamo.
    </p>
    <p class="text-gray-700 dark:text-gray-300 mb-4">
      Con SimularCred puedes descargar tu tabla de amortización en <strong>PDF</strong> o <strong>CSV</strong> para llevarla al banco, compartirla con tu asesor financiero o simplemente guardarla como referencia.
    </p>
  </section>

  <AdUnit slot="mid-ad" format="rectangle" />

  <!-- Popular Simulations -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-6">Simulaciones Populares</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {popularCombos.map((combo) => (
        <a
          href={`/simulador/${combo.slug}`}
          class="block bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 hover:border-primary-400 hover:shadow-md transition-all"
        >
          <p class="font-semibold text-primary-800 dark:text-primary-400 text-sm mb-1">{combo.title}</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">{combo.description.slice(0, 80)}…</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Guides Section -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-6">Guías de Amortización</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {[
        { href: '/guias/sistema-frances', title: 'Sistema Francés', desc: 'Cuota fija durante todo el plazo. Ideal para planificación financiera.' },
        { href: '/guias/sistema-aleman', title: 'Sistema Alemán', desc: 'Capital fijo, intereses decrecientes. Menor costo total.' },
        { href: '/guias/como-calcular-cuota', title: 'Cómo Calcular tu Cuota', desc: 'Aprende la fórmula matemática paso a paso.' },
        { href: '/guias/comparar-creditos', title: 'Comparar Créditos', desc: 'Cómo elegir entre distintas ofertas de crédito.' },
      ].map((g) => (
        <a href={g.href} class="bg-primary-50 dark:bg-primary-900/20 border border-primary-100 dark:border-primary-800 rounded-xl p-5 hover:bg-primary-100 dark:hover:bg-primary-900/40 transition-colors">
          <h3 class="font-bold text-primary-800 dark:text-primary-400 mb-2">{g.title}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">{g.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Countries Section -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-primary-800 dark:text-primary-400 mb-6">Por País</h2>
    <div class="flex flex-wrap gap-3">
      {[
        { href: '/paises/mexico', label: '🇲🇽 México' },
        { href: '/paises/colombia', label: '🇨🇴 Colombia' },
        { href: '/paises/argentina', label: '🇦🇷 Argentina' },
        { href: '/paises/chile', label: '🇨🇱 Chile' },
        { href: '/paises/peru', label: '🇵🇪 Perú' },
        { href: '/paises/estados-unidos', label: '🇺🇸 Estados Unidos' },
      ].map((p) => (
        <a href={p.href} class="px-5 py-2.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full font-medium hover:border-primary-400 hover:text-primary-700 dark:hover:text-primary-400 transition-colors">
          {p.label}
        </a>
      ))}
    </div>
  </section>

  <AdUnit slot="bottom-ad" format="horizontal" />

  <FAQ items={faqs} />
</LandingLayout>
