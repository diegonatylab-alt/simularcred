---
import LandingLayout from '../../layouts/LandingLayout.astro';
import Calculator from '../../components/Calculator';
import FAQ from '../../components/FAQ.astro';

const faqs = [
  {
    question: '¿Cuál es la fórmula para calcular la cuota mensual?',
    answer: 'Para sistema francés: M = P × [r(1+r)^n] / [(1+r)^n - 1]. Para sistema alemán: cuota variable = capital fijo + intereses del saldo.',
  },
  {
    question: '¿Cómo calculo la tasa mensual a partir de la tasa anual?',
    answer: 'Divide la tasa anual entre 12. Ejemplo: tasa anual 12% → tasa mensual = 12% / 12 = 1% = 0.01.',
  },
];
---

<LandingLayout
  title="Cómo Calcular tu Cuota de Préstamo | SimularCred"
  description="Aprende paso a paso cómo calcular la cuota mensual de un préstamo usando los sistemas francés y alemán. Con fórmulas y ejemplos prácticos."
  canonical="https://simuladorcredito.lat/guias/como-calcular-cuota"
  breadcrumbs={[
    { label: 'Inicio', href: '/' },
    { label: 'Guías' },
    { label: 'Cómo Calcular Cuota' },
  ]}
>
  <article class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-extrabold text-primary-900 mb-4">Cómo Calcular tu Cuota de Préstamo</h1>
    <p class="text-lg text-gray-600 mb-8">
      Calcular la cuota mensual de un préstamo requiere conocer tres datos: el monto, la tasa de interés y el plazo. Te explicamos cómo hacerlo con las fórmulas paso a paso.
    </p>

    <h2 class="text-2xl font-bold text-primary-800 mb-3">Paso 1: Convertir la tasa anual a mensual</h2>
    <div class="bg-primary-50 rounded-xl p-4 mb-4">
      <code class="font-mono text-primary-900">r_mensual = tasa_anual / 100 / 12</code>
    </div>
    <p class="text-gray-700 mb-6">Ejemplo: 12% anual → r = 0.12/12 = 0.01 (1% mensual)</p>

    <h2 class="text-2xl font-bold text-primary-800 mb-3">Paso 2: Calcular número de cuotas</h2>
    <div class="bg-primary-50 rounded-xl p-4 mb-4">
      <code class="font-mono text-primary-900">n = años × 12</code>
    </div>
    <p class="text-gray-700 mb-6">Ejemplo: 5 años → n = 60 cuotas</p>

    <h2 class="text-2xl font-bold text-primary-800 mb-3">Paso 3: Aplicar la fórmula (Sistema Francés)</h2>
    <div class="bg-primary-50 rounded-xl p-4 mb-4">
      <code class="font-mono text-primary-900">M = P × [r(1+r)^n] / [(1+r)^n - 1]</code>
    </div>
    <p class="text-gray-700 mb-4">Con P=100,000, r=0.01, n=60:</p>
    <p class="text-gray-700 mb-6">M = 100,000 × [0.01×(1.01)^60] / [(1.01)^60 - 1] ≈ <strong>2,224.45</strong></p>

    <h2 class="text-2xl font-bold text-primary-800 mb-3">Prueba el Simulador</h2>
    <p class="text-gray-600 mb-4">Usa nuestra calculadora para obtener la tabla completa al instante:</p>
  </article>

  <div class="max-w-4xl mx-auto mt-4 mb-10">
    <Calculator client:visible />
  </div>

  <div class="max-w-4xl mx-auto">
    <FAQ items={faqs} />
    <div class="mt-8 flex flex-wrap gap-4 text-sm">
      <a href="/guias/sistema-frances" class="text-primary-700 underline">→ Sistema Francés</a>
      <a href="/guias/sistema-aleman" class="text-primary-700 underline">→ Sistema Alemán</a>
    </div>
  </div>
</LandingLayout>
