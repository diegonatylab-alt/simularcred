---
interface Props {
  slot: string;
  format: 'horizontal' | 'rectangle' | 'vertical' | 'auto';
}

const { slot, format = 'auto' } = Astro.props;

const layoutMap: Record<string, string> = {
  horizontal: 'in-article',
  rectangle: 'in-article',
  vertical: 'in-article',
  auto: 'in-article',
};
---

<div class="ad-unit my-4 min-h-[100px] overflow-hidden">
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-3904107966422584"
    data-ad-slot={slot}
    data-ad-format="fluid"
    data-ad-layout-key="-6t+ed+2i-1n-4w"
    data-ad-layout={layoutMap[format]}
  ></ins>
</div>

<script is:inline>
  (function(){
    var ads = document.querySelectorAll('.ad-unit');
    var observer = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if(entry.isIntersecting){
          try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch(e){}
          observer.unobserve(entry.target);
        }
      });
    }, { rootMargin: '200px' });
    ads.forEach(function(el){ observer.observe(el); });
  })();
</script>
