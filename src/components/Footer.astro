          <li><a href="/paises/estados-unidos" class="hover:text-white transition-colors">Estados Unidos</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-3">Legal</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/sobre-nosotros" class="hover:text-white transition-colors">Acerca de</a></li>
          <li><a href="/politica-privacidad" class="hover:text-white transition-colors">Política de Privacidad</a></li>
