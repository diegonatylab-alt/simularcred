  <div class="container">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
      <div>
        <h3 class="text-white font-bold mb-3">SimularCred</h3>
        <p class="text-sm text-gray-400">Calculadora de créditos para América Latina.</p>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-3">Guías</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/guias/sistema-frances" class="hover:text-white transition-colors">Sistema Francés</a></li>
          <li><a href="/guias/sistema-aleman" class="hover:text-white transition-colors">Sistema Alemán</a></li>
          <li><a href="/guias/como-calcular-cuota" class="hover:text-white transition-colors">Calcular Cuota</a></li>
          <li><a href="/guias/comparar-creditos" class="hover:text-white transition-colors">Comparar Créditos</a></li>
